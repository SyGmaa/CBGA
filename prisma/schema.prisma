// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  PRODI
  PJPJK
}

enum Hari {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

enum StatusPreferensi {
  AVAILABLE
  UNAVAILABLE
}

enum SemesterTipe {
  Ganjil
  Genap
}

enum StatusJadwal {
  DRAFT
  GENERATING
  FINAL
}

// ============================================================
// MODELS
// ============================================================

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  email    String @unique
  password String
  role     Role

  // Relation to Prodi (optional, mainly for Role.PRODI)
  idProdi  Int?   @map("id_prodi")
  prodi    Prodi? @relation(fields: [idProdi], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Fakultas {
  id           Int      @id @default(autoincrement())
  namaFakultas String   @unique @map("nama_fakultas")
  
  prodi        Prodi[]

  @@map("fakultas")
}

model Prodi {
  id        Int    @id @default(autoincrement())
  namaProdi String @map("nama_prodi")
  kodeProdi String @unique @map("kode_prodi")

  idFakultas Int      @map("id_fakultas")
  fakultas   Fakultas @relation(fields: [idFakultas], references: [id])

  users      User[]
  mataKuliah MataKuliah[]
  dosen      Dosen[] // Homebase dosen

  @@map("prodi")
}

model SlotWaktu {
  id        Int    @id @default(autoincrement())
  hari      Hari
  jamMulai  String @map("jam_mulai")
  jamSelesai String @map("jam_selesai")

  preferensiWaktuDosen PreferensiWaktuDosen[]
  jadwalDetail         JadwalDetail[]

  @@unique([hari, jamMulai, jamSelesai])
  @@map("slot_waktu")
}

model Gedung {
  id         Int       @id @default(autoincrement())
  namaGedung String    @unique @map("nama_gedung")
  ruangan    Ruangan[]

  @@map("gedung")
}

model Ruangan {
  id          Int    @id @default(autoincrement())
  namaRuangan String @map("nama_ruangan")
  
  idGedung    Int    @map("id_gedung")
  gedung      Gedung @relation(fields: [idGedung], references: [id])
  
  kapasitas   Int

  jadwalDetail JadwalDetail[]

  @@map("ruangan")
}

model MataKuliah {
  id        Int    @id @default(autoincrement())
  kodeMk    String @unique @map("kode_mk")
  namaMk    String @map("nama_mk")
  sks       Int
  semester  Int
  jumlahMhs Int    @map("jumlah_mhs")
  isAktif   Boolean @default(true) @map("is_aktif")

  idProdi   Int    @map("id_prodi")
  prodi     Prodi  @relation(fields: [idProdi], references: [id])

  jadwalDetail JadwalDetail[]

  @@map("mata_kuliah")
}

model Dosen {
  id        Int    @id @default(autoincrement())
  nidn      String @unique
  namaDosen String @map("nama_dosen")

  // Homebase Prodi (Optional)
  idProdi   Int?   @map("id_prodi")
  prodi     Prodi? @relation(fields: [idProdi], references: [id])

  preferensiWaktu PreferensiWaktuDosen[]
  jadwalDetail    JadwalDetail[]

  @@map("dosen")
}

model PreferensiWaktuDosen {
  id          Int              @id @default(autoincrement())
  idDosen     Int              @map("id_dosen")
  idSlotWaktu Int              @map("id_slot_waktu")
  status      StatusPreferensi

  dosen     Dosen     @relation(fields: [idDosen], references: [id], onDelete: Cascade)
  slotWaktu SlotWaktu @relation(fields: [idSlotWaktu], references: [id], onDelete: Cascade)

  @@unique([idDosen, idSlotWaktu])
  @@map("preferensi_waktu_dosen")
}

model JadwalMaster {
  id            Int          @id @default(autoincrement())
  tahunAkademik String       @map("tahun_akademik")
  semesterTipe  SemesterTipe @map("semester_tipe")
  status        StatusJadwal @default(DRAFT)
  fitnessScore  Float?       @map("fitness_score")
  conflictCount Int          @default(0) @map("conflict_count")

  jadwalDetail JadwalDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jadwal_master")
}

model JadwalDetail {
  id            Int @id @default(autoincrement())
  idJadwalMaster Int @map("id_jadwal_master")
  idMatkul      Int @map("id_matkul")
  idDosen       Int @map("id_dosen")
  idRuangan     Int @map("id_ruangan")
  idSlotWaktu   Int @map("id_slot_waktu")

  jadwalMaster JadwalMaster @relation(fields: [idJadwalMaster], references: [id], onDelete: Cascade)
  mataKuliah   MataKuliah   @relation(fields: [idMatkul], references: [id])
  dosen        Dosen        @relation(fields: [idDosen], references: [id])
  ruangan      Ruangan      @relation(fields: [idRuangan], references: [id])
  slotWaktu    SlotWaktu    @relation(fields: [idSlotWaktu], references: [id])

  @@map("jadwal_detail")
}
